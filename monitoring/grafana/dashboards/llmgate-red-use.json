      },
      "targets": [
        {
          "expr": "sum(rate(llmgate_requests_total{error_kind!=\"none\"}[5m])) / clamp_min(sum(rate(llmgate_requests_total[5m])), 0.001)",
          "legendFormat": "all errors",
          "refId": "A"
        },
        {
          "expr": "sum(rate(llmgate_requests_total{error_kind=~\"upstream|timeout|panic|empty_response|client_closed\"}[5m])) / clamp_min(sum(rate(llmgate_requests_total[5m])), 0.001)",
          "legendFormat": "gateway/vendor errors",
          "refId": "B"
        },
        {
          "expr": "sum(rate(llmgate_requests_total{error_kind=~\"auth|bad_request|forbidden\"}[5m])) / clamp_min(sum(rate(llmgate_requests_total[5m])), 0.001)",
          "legendFormat": "caller errors",
          "refId": "C"
        }
      ],
      "title": "Gateway error ratio",
      "type": "timeseries"
