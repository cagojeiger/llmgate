# llmgate — vendor credentials & defaults (template).
# Copy to .env and fill the key. .env is git-ignored.

# Required: API key for the upstream named in catalog auth_env.
LLMGATE_OPENCODE_API_KEY=
LLMGATE_OPENROUTER_API_KEY=

# Optional: point at an external catalog directory (must contain
# models/ subdir; aliases/ is optional). Defaults to ./catalog
# (relative to cwd) — `make run` from the repo root picks up the
# bundled catalog/ automatically.
# LLMGATE_CATALOG=/etc/llmgate/catalog

# Optional server tunables (defaults shown).
# LLMGATE_ADDR=:8080
# LLMGATE_LOG_LEVEL=info
# Maximum app-side wait for in-flight requests to drain on SIGTERM
# before force-closing remaining connections. Pair with the
# orchestrator's terminationGracePeriodSeconds (k8s) /
# stop_grace_period (compose) — set those slightly larger so the
# graceful force close fires before SIGKILL.
# LLMGATE_SHUTDOWN_DRAIN_TIMEOUT=5m

# Optional router tuning (defaults shown). Comma-separated provider.Kind
# values for fallback eligibility; circuit breaker trips after N
# consecutive failures and skips the model for the cooldown duration.
# Set CIRCUIT_FAILURES=0 or CIRCUIT_OPEN_DURATION=0s to disable the
# breaker entirely.
# LLMGATE_FALLBACK_ON=rate_limit,upstream,timeout,network
# LLMGATE_CIRCUIT_FAILURES=3
# LLMGATE_CIRCUIT_OPEN_DURATION=30s

# Optional NATS JetStream delivery for finalized OpenAI-compatible LLM results.
# Leave URL unset to disable.
# LLMGATE_NATS_URL=nats://localhost:4222
# LLMGATE_NATS_STREAM=LLMGATE_LLM_RESULTS
# LLMGATE_NATS_SUBJECT=llmgate.llm.results.v1
# LLMGATE_NATS_QUEUE_SIZE=10000
# LLMGATE_NATS_WORKERS=1
# LLMGATE_NATS_BATCH_SIZE=100
# LLMGATE_NATS_BATCH_MAX_WAIT=1s
# LLMGATE_NATS_ENQUEUE_TIMEOUT=100ms
# LLMGATE_NATS_SEND_TIMEOUT=3s
# LLMGATE_NATS_FLUSH_TIMEOUT=15s

# --- Client-side env for agents that *consume* this gateway ----------
# Used by scripts/ that call the deployed llmgate over its OpenAI-
# compatible /v1 endpoint. Unrelated to the LLMGATE_* server tunables
# above — those configure the gateway itself; these point at it.
# Override LLMGATE_BASE_URL for local testing (e.g. http://localhost:8080/v1).
# LLMGATE_BASE_URL=https://llmgate.project-jelly.io/v1
LLMGATE_CONSUMER_KEY=
