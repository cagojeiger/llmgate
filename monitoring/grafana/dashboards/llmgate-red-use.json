      "id": 1,
      "options": {
        "content": "Use this as the incident first screen. The default view stays small; expand rows only when a signal needs drill-down.\n\n1. Check Gateway RED first: traffic, caller/vendor error split, and success latency.\n2. If Gateway RED is bad, compare caller errors (`auth`, `bad_request`, `forbidden`) with gateway/vendor errors.\n3. If LLM signals are suspicious, expand **LLM routing and performance** or open the dedicated LLM dashboard.\n4. If latency rises without LLM evidence, expand **Runtime resources** or open the runtime dashboard.\n5. Cost, users, prompts, responses, and quality analysis belong in logs/traces, not Prometheus labels.",
        "mode": "markdown"
      },
      "pluginVersion": "12.3.0",
      "title": "How to read this dashboard",
      "type": "text"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "never"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 7
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum by (operation) (rate(llmgate_requests_total[5m]))",
          "legendFormat": "{{operation}}",
          "refId": "A"
        }
      ],
      "title": "Gateway request rate",
      "type": "timeseries"
    },
